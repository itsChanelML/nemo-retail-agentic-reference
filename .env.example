# ── NVIDIA NIM ─────────────────────────────────────────────────────────────
# Required. Get free key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Best Buy API ────────────────────────────────────────────────────────────
# Free. Instant approval (no manual review).
# Get your key at: https://developer.bestbuy.com
# If not set, ShopMind falls back to the 45-product seed catalog.
BESTBUY_API_KEY=your-bestbuy-api-key-here

# ── Frontend ────────────────────────────────────────────────────────────────
# Leave empty on Vercel (uses rewrites). Set to http://localhost:8000 for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8000
